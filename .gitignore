# Environment files — ALL .env variants stay internal, no exceptions
.env
.env.*
**/.env
**/.env.*
packages/*/.env
packages/*/.env.*

# Database migrations / schema — stays internal
supabase/
**/supabase/migrations/

# Documentation files (keep repo clean)
# Only ignore PDFs, keep all .md files
*.pdf

# Dependencies
node_modules/
packages/*/node_modules/

# Build outputs
dist/
packages/*/dist/
build/
packages/*/build/

# Solana build artifacts
packages/void402-solana/target/
packages/void402-solana/.mint_address.txt

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
*.tmp
*.temp

.env*.local
.vercel
nolvi-compare/

# Internal docs — keep public repo doc-free except README
*.md
!README.md

# Any file naming Nolvi, ORB, or ORB402 stays internal
*[Nn]olvi*
*[Oo]rb*
*ORB*
