{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/zk/process-pending-exchanges.ts": { "maxDuration": 300 },
    "api/zk/process-split-queue.ts": { "maxDuration": 120 },
    "api/zk/auto-split-and-exchange.ts": { "maxDuration": 120 },
    "api/zk/withdraw.ts": { "maxDuration": 300 },
    "api/zk/transfer.ts": { "maxDuration": 120 },
    "api/farcaster/cast-payment.ts": { "maxDuration": 120 },
    "api/farcaster/bot-cron.ts": { "maxDuration": 60 }
  },
  "rewrites": [
    { "source": "/.well-known/farcaster.json", "destination": "/farcaster.json" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/zk/process-pending-exchanges",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/x402/process-deposits",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/farcaster/bot-cron",
      "schedule": "0 */6 * * *"
    }
  ]
}
